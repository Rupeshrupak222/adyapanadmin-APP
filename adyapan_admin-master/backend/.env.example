# ─── Database (TiDB Cloud / MySQL) ───────────────────────────────────
# IMPORTANT: This MUST point to the same database as all other Adyapan projects
DATABASE_URL="mysql://username:password@gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com:4000/preschool?sslaccept=strict"

# Raw MySQL (for leaves, meetings routes)
MYSQL_HOST=gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com
MYSQL_PORT=4000
MYSQL_USER=username
MYSQL_PASSWORD=password
MYSQL_DATABASE=preschool
MYSQL_SSL=true

# ─── JWT ─────────────────────────────────────────────────────────────
# IMPORTANT: JWT_SECRET must be the SAME across all 3 projects (Preschool, adyapanschool, adyapan_admin)
# so that tokens issued by one backend are valid on the others.
JWT_SECRET=your-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Server ─────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS (comma-separated origins for production) ───────────────────
# Leave empty for dev (allows all). Set for production:
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com
CORS_ORIGINS=

# ─── ADMIN ──────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@adyapan.com
ADMIN_PASSWORD=Admin@Ady2026!
ADMIN_ACCESS_KEY=ADMIN-ADY-2026

# ─── TEACHER ────────────────────────────────────────────────────────
TEACHER_EMAIL=teacher@gmail.com
TEACHER_PASSWORD=Teacher@Ady2026!
TEACHER_STAFF_KEY=STAFF-ADY-2026

# ─── PRINCIPAL ──────────────────────────────────────────────────────
PRINCIPAL_EMAIL=principal@adyapan.com
PRINCIPAL_PASSWORD=Principal@Ady2026!
PRINCIPAL_ACCESS_KEY=SCHOOL-ADY-2026
